# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
# Generate a strong secret for production.
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_VALUE
JWT_EXPIRES_IN=24h

# Encryption Key for API Keys (32+ characters for AES-256)
ENCRYPTION_KEY=CHANGE_ME_TO_32+_CHARS_MINIMUM

# Database
DATABASE_PATH=./storage/database.sqlite

# Storage Paths
DOCUMENTS_PATH=./storage/documents
EMBEDDINGS_PATH=./storage/embeddings

# LLM Provider API Keys (Optional - can be configured per agent)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
# DASHSCOPE_API_KEY=  # (or QWEN_API_KEY)
KIMI_API_KEY=
MOONSHOT_API_KEY=
# Kimi/Moonshot Base URL (international: https://api.moonshot.ai/v1, China: https://api.moonshot.cn/v1)
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=qwen3-vl:4b

# MCP Tool Configuration
# Email Tool (optional; required only if email tool enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Web Search Tool (optional)
BRAVE_SEARCH_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000000

# Context controls
DEFAULT_MESSAGE_LIMIT_CONTEXT_LENGTH=10

# Media tool timeouts (optional)
PDF_VISION_TIMEOUT_MS=600000
PDF_PARSE_TIMEOUT_MS=120000
PDFTOPPM_TIMEOUT_MS=180000
PROCESS_MEDIA_TOOL_TIMEOUT_MS=600000

# Prevent error: 400 "Value looks like object, but can't find closing '}' symbol"
# remove it entirely to use default 51200
OLLAMA_MAX_REQUEST_BYTES=50000

# Superuser username (optional; leave empty to disable superuser features)
SUPERUSER_NAME=

# System-enabled tools (comma-separated). Only these are shown in Tools view and Configure Session → Tools.
# Empty or commented = show all tools.
# ENABLED_TOOLS=web_search,webhook_request,process_media,sqlite_local_db,local_working_folder,workspace_exec,state_persist,session_pool,ef_api,archived_conversation_history,conversation_rounds,session_schedule,calculate_depreciation,categorize_business_expense,calculate_business_ratios,convert_currency
